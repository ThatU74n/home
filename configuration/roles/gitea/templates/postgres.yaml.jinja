---
services:
  postgres:
    container_name: postgres
    image: postgres:{{ gitea_postgres_tag }}
    restart: always
    labels:
      - app=gitea 
    environment:
      POSTGRES_USER: {{ gitea_postgres_super_user }}
      POSTGRES_PASSWORD: {{ gitea_postgres_super_password }}
      POSTGRES_HOST_AUTH_METHOD: scram-sha-256
    command: postgres -c password_encryption=scram-sha-256
    volumes:
{% if gitea_postgres_data_path is defined %}
      - {{ gitea_postgres_data_path }}:/var/lib/postgresql/data
{% else %}
      - postgres_data:/var/lib/postgresql/data 
{% endif %}
    ports:
      - 127.0.0.1:5432:5432
    networks:
      - gitea_network

{% if gitea_postgres_data_path == "" %}
volumes:
  postgres_data:
    name: postgres_data
    external: true
{% endif %}

networks:
  gitea_network:
    name: gitea_network
    external: true
    

