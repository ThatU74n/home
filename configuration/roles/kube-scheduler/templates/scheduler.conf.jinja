---
apiVersion: v1
kind: Config
clusters:
  - cluster:
      certificate-authority-data: {{ kubernetes_ca_cert_content | b64encode }}
      server: https://127.0.0.1:6443
    name: kubernetes
contexts:
  - context:
      cluster: kubernetes
      user: system:kube-scheduler
    name: system:kube-scheduler@kubernetes
current-context: system:kube-scheduler@kubernetes
users:
  - name: system:kube-scheduler
    user:
      client-certificate-data: {{ kube_scheduler_cert.content }}
      client-key-data: {{ kube_scheduler_key.content }}
