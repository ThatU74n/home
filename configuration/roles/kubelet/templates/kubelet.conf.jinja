apiVersion: v1
kind: Config
clusters:
  - cluster:
      certificate-authority-data: {{ kubernetes_ca_cert_content | b64encode }}
      server: https://127.0.0.1:6443
    name: kubernetes
contexts:
  - context:
      cluster: kubernetes
      user: system:node:{{ inventory_hostname }}
    name: system:node:{{ inventory_hostname }}@kubernetes
current-context: system:node:{{ inventory_hostname }}@kubernetes
users:
  - name: system:node:{{ inventory_hostname }}
    user:
      client-certificate-data: {{ kubelet_cert.content }}
      client-key-data: {{ kubelet_key.content }}
